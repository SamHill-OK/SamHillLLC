@page "/"

<PageTitle>SamHill LLC</PageTitle>

<div class="site-page">

    <section class="hero">

        <div class="hero-content">

            <img src="images/samhill-logo.png"
                 alt="SamHill LLC"
                 class="company-logo" />

            <h1>Software Solutions for Congregations</h1>

            <p>
                Practical tools that help congregations organize worship services,
                connect members, and support ministry work.
            </p>

            <div class="hero-actions">
                <a href="#products" class="btn-primary">View Products</a>
                <a href="mailto:manderson@samhillllc.com" class="btn-secondary">Contact Us</a>
            </div>

        </div>

    </section>

    <section id="products" class="section">

        <div class="section-heading">
            <h2>Our Products</h2>
            <p>Built to serve congregations with simple, useful, affordable software.</p>
        </div>

        <div class="product-grid">

            <div class="product-card">
                <img src="images/wsp-logo.png" alt="Worship Service Planner" />

                <h3>Worship Service Planner</h3>

                <p>
                    Plan worship services, manage assignments, communicate with members,
                    and keep service details organized.
                </p>
            </div>

            <div class="product-card">
                <img src="images/servicelink-logo.png" alt="ServiceLink" />

                <h3>ServiceLink</h3>

                <p>
                    Help members view assignments, respond to service requests,
                    and stay connected to the work of the congregation.
                </p>
            </div>

            <div class="product-card">
                <img src="images/servicelink-icon.png" alt="Elder Tools" />

                <h3>Elder Tools</h3>

                <p>
                    Connection Tool, Go Forward follow-up, Elder of the Month,
                    and Elder Meeting Scheduler support.
                </p>
            </div>

        </div>

    </section>

    <section class="section split-section">

        <div>
            <h2>About SamHill LLC</h2>

            <p>
                SamHill LLC is the public brand of Sam Hill Business Services LLC,
                an Oklahoma limited liability company.
            </p>

            <p>
                We focus on practical software that solves real congregation
                workflow problems without adding unnecessary complexity.
            </p>
        </div>

        <div class="info-box">
            <h3>Contact</h3>

            <p>
                <strong>Email:</strong><br />
                <a href="mailto:manderson@samhillllc.com">manderson@samhillllc.com</a>
            </p>

            <p>
                <strong>Location:</strong><br />
                Durant, Oklahoma
            </p>
        </div>

    </section>

    <footer>
        © 2026 Sam Hill Business Services LLC. All rights reserved.
    </footer>

</div>